{
  "version": "0.3.0",
  "updated_at": "2026-07-18",
  "skills": ["generate-image", "generate-video"],
  "models": {
    "image": [
      {"id": "seedream-5.0", "provider": "bytedance"},
      {"id": "nano banana pro", "provider": "google"},
      {"id": "imagen 4 ultra", "provider": "google"},
      {"id": "gpt-image-2", "provider": "openai"}
    ],
    "video": [
      {"id": "kling-text2video", "provider": "kling"},
      {"id": "kling-image2video", "provider": "kling"},
      {"id": "kling-omni-video", "provider": "kling"}
    ]
  },
  "api": {
    "image": {
      "submit": "POST /v1/image-generations",
      "query": "GET /v1/image-generations/{taskId}",
      "submit_body": {"text": "string", "model": "string", "resolution": "string?", "ratio": "string?", "count": "int?", "imageUrls": "string[]?"},
      "query_body": {"taskId": "string", "status": "string", "images": "string[]?(字符串化JSON)", "errorMessage": "string?"},
      "status_terminal": ["success", "failed"]
    },
    "video": {
      "submit": "POST /v1/video-generations",
      "query": "GET /v1/video-generations/{taskId}",
      "submit_body": {"text": "string", "model": "string", "videoType": "int?", "resolution": "string?", "ratio": "string?", "duration": "long?", "imageUrls": "string[]?", "videoUrls": "[{videoUrl,referType?,keepOriginalSound?}]?", "audioUrls": "string[]?", "elementIds": "long[]?", "multiPrompt": "[{index,prompt,duration?}]?", "urls": "string[]?"},
      "status_terminal": ["success", "failed"]
    },
    "poll_interval_seconds": 15
  },
  "video_types": {
    "1": {"name": "Text to Video", "desc": "文生视频", "fields": ["text"], "needs_reference": false},
    "2": {"name": "Image to Video (First Frame)", "desc": "图生视频-首帧", "fields": ["text", "imageUrls"], "needs_reference": true, "note": "imageUrls[0]=首帧"},
    "3": {"name": "Image to Video (Head-Tail Frame)", "desc": "图生视频-首尾帧", "fields": ["text", "imageUrls"], "needs_reference": true, "note": "imageUrls[0]=首帧,[1]=尾帧"},
    "4": {"name": "Image to Video (Reference)", "desc": "多图参考", "fields": ["text", "imageUrls或urls"], "needs_reference": true, "note": "多张参考图"},
    "5": {"name": "Omni Reference", "desc": "全能参考(图/视频/音频/主体)", "fields": ["text", "imageUrls", "videoUrls", "audioUrls", "elementIds", "multiPrompt?"], "needs_reference": true, "prompt_syntax": "提示词可用 @图片N / @视频N / @音频N 引用素材(从1起)。各 provider 处理不同: Kling 转 <<<image_N>>> 占位并校验序号≤数组长度(音频不入引用, audioUrls 直接传作 sound_file); BytePlus/seedance 转成纯文本'图片N'描述(不校验, 音频也支持@音频N转文本)。element 用 <<<element_N>>>。例: 参考@图片1的男生和@图片2的女生..."},
    "6": {"name": "Digital Human", "desc": "数字人", "fields": ["text", "imageUrls", "audioUrls"], "needs_reference": true, "note": "imageUrls[0]=形象, audioUrls[0]=驱动音频"}
  },
  "provider_notes": {
    "kling": "全能参考(code5): @图片N/@视频N 转 <<<image_N>>>/<<<video_N>>> 精确引用 imageUrls/videoUrls 数组下标, 序号超数组长度会报错; 音频直接传 audioUrls(取第一个作 sound_file), 不用 @音频N; elementIds 配 <<<element_N>>>",
    "byteplus": "seedance 全能参考(code5): @图片N/@视频N/@音频N 转成纯文本'图片N'等描述(不校验序号); imageUrls/videoUrls/audioUrls 各自作独立 content item 上传; 无精确数组关联, 靠文本+素材顺序",
    "alibailian": "支持类型 1/2/3/4(无全能参考5); audioUrls 取第一个作 audio_url"
  },
  "model_specs": {
    "image_endpoint": "GET /v1/image-models",
    "video_endpoint": "GET /v1/video-models",
    "image_spec_fields": ["id", "displayName", "description", "maxCount", "fileMax", "resolutions", "ratios", "resolutionOptions"],
    "video_spec_fields": ["id", "displayName", "description", "allowedVideoTypes", "videoDurationMin", "videoDurationMax", "videoDurationSuggest", "resolutions", "ratios", "resolutionOptions"],
    "note": "allowedVideoTypes 只返回 code+name; 每种类型的素材限制见上方 video_types",
    "cache_dir": "~/.media-gen/cache/",
    "last_choice": "~/.media-gen/cache/last-choice.json"
  }
}
